# THE Brain — Local Development Environment Variables
# Copy this file to .dev.vars and fill in real values
# .dev.vars is gitignored — never commit secrets

# Neon Postgres connection string (used directly by the Hindsight container)
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
NEON_CONNECTION_STRING=postgresql://user:password@localhost:5432/brain_dev

# Cloudflare AI Gateway ID (created in dashboard)
AI_GATEWAY_ID=haetsal-brain-gateway

# Cloudflare account id for AI Gateway compat URL
AI_GATEWAY_ACCOUNT_ID=d3f0a1c579945862edc9c6f6e36e448a

# Cloudflare AI Gateway token (gateway auth; provider key stays in AI Gateway BYOK)
AI_GATEWAY_TOKEN=cf-aig-xxxxxxxxxxxx
